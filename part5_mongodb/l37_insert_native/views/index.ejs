<!DOCTYPE html>
<html lang="en">
  <%- include('layout/head.ejs') %>
  <body>
    <%- include('layout/nav.ejs') %>
    <div class="content">
        <% if (posts.length > 0) { %>
          <% posts.forEach(post => { %>
            <h3><%= post.title %></h3>
            <small><%= post.subtitle %></small>
            <p><%= post.body %></p>
          <% }) %>
        <% } else { %>
            <p>There are no blog posts to display.</p>
        <% } %>

    </div>
      <%- include('layout/footer.ejs') %>
  </body>
</html>
