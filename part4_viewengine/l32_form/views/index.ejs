<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <title><%= title %></title>
  </head>
  <body>
    <% const greeting = "Welcome to EJS Lesson" %>

    <nav>
      <div>
        <a href="/">Home Page</a>
        <p><%= greeting %></p>
      </div>
      <ul>
        <li><a href="/">Home Page</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/posts/create">Create Post</a></li>
      </ul>
    </nav>
    <div>
        <% if (posts.length > 0) { %>
          <% posts.forEach(post => { %>
            <h3><%= post.title %></h3>
            <small><%= post.subtitle %></small>
            <p><%= post.body %></p>
          <% }) %>
        <% } else { %>
            <p>There are no blog posts to display.</p>
        <% } %>

    </div>
  </body>
</html>
